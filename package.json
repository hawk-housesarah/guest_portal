    "dotenv": "^17.2.3",
    "html2canvas": "^1.4.1",
    "libphonenumber-js": "^1.12.24",
    "nuxt": "^4.1.2",
    "pinia": "^3.0.3",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
